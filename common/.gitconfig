[user]
  name = Bruno Leonardo Michels
  email = brunolm7@gmail.com
  signingkey = E431F460E263C126
[core]
  autocrlf = input
  editor = \"C:\\Program Files\\Microsoft VS Code Insiders\\Code - Insiders.exe\" --wait
  longpaths = true
[color]
  ui = true
[push]
  default = current
[alias]
  alias = config --get-regexp '^alias\\.'
  l = "!f() { git log --oneline -${1:-10}; }; f"
  lob = "!git log --oneline $(git merge-base HEAD main)..HEAD"
  lga = log --graph --oneline --all --decorate
  fa = fetch --all --prune
  s = status
  p = pull
  ps = push
  pfl = push --force-with-lease
  fp = !git fetch --all --prune && git pull
  c = checkout
  cb = checkout -b
  cm = checkout main
  re = !git reset HEAD -- . && git checkout -- . && git clean -fd
  wt = "!f() { project=$(basename \"$(git rev-parse --show-toplevel)\"); name=$1; shift; hash=$(printf '%s' \"$name\" | git hash-object --stdin | cut -c1-8); wtpath=\"$(git rev-parse --show-toplevel)/../${project}-worktrees/$hash\"; if [ $# -eq 0 ]; then if git rev-parse --verify \"$name\" >/dev/null 2>&1 || git rev-parse --verify \"origin/$name\" >/dev/null 2>&1; then git worktree add \"$wtpath\" \"$name\"; else git worktree add -b \"$name\" \"$wtpath\"; fi; else git worktree add \"$wtpath\" \"$@\"; fi; }; f"
  wtrm = "!f() { project=$(basename \"$(git rev-parse --show-toplevel)\"); name=$1; hash=$(printf '%s' \"$name\" | git hash-object --stdin | cut -c1-8); wtpath=\"$(git rev-parse --show-toplevel)/../${project}-worktrees/$hash\"; git worktree remove \"$wtpath\"; }; f"
[commit]
  gpgsign = true
[gpg]
	program = C:\\Program Files (x86)\\gnupg\\bin\\gpg.exe
[winUpdater]
	recentlySeenVersion = 2.23.0.windows.1
[credential "https://git.heroku.com"]
	provider = generic
[safe]
	directory = *
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[credential "https://huggingface.co"]
	provider = generic
